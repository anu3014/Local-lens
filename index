<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LocalLens | Connected Communities</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <nav>
        <div class="nav-container">
            <div class="logo" onclick="showView('landing')">
                <i class="fas fa-bullseye"></i> LocalLens
            </div>
            <div class="nav-links" id="nav-links">
                </div>
        </div>
    </nav>

    <main id="app">
        <section id="landing-view" class="view hero-section">
            <span class="hero-tagline">✦ HYPERLOCAL · CIVIC · OPEN</span>
            <h1 class="hero-title">Spot it. Snap it.<br><span class="gradient-text">Solve it.</span></h1>
            <p class="hero-p">LocalLens turns every neighbor into a citizen-reporter. We route your reports directly to the right office and track them to resolution.</p>
            <div class="hero-btns">
                <button class="btn-report" onclick="showView('report')">Report an Issue →</button>
                <button class="btn-secondary" onclick="showView('feed')">Browse the Feed</button>
            </div>
            
            <div class="steps-row">
                <div class="step-card">
                    <span class="step-num">01</span>
                    <h3>Spot it</h3>
                    <p>See a pothole, busted streetlight, or overflowing bin? You're a reporter now.</p>
                </div>
                <div class="step-card">
                    <span class="step-num">02</span>
                    <h3>Snap it</h3>
                    <p>Open LocalLens, snap a photo. Location is auto-tagged — no typing required.</p>
                </div>
                <div class="step-card">
                    <span class="step-num">03</span>
                    <h3>Solve it</h3>
                    <p>We ping you the moment a worker is dispatched and when the job is done.</p>
                </div>
            </div>
        </section>

        <section id="feed-view" class="view hidden">
            <div class="view-header">
                <div>
                    <h1>Community Feed</h1>
                    <p>Real-time civic updates from your neighbors.</p>
                </div>
                <button class="btn-report" onclick="showView('report')">+ Report Issue</button>
            </div>
            <div id="feed-container"></div>
        </section>

        <section id="report-view" class="view hidden">
            <h1>Report an Issue</h1>
            <p class="subtitle">Help us pinpoint the problem. Data is encrypted and secure.</p>
            <div class="form-card">
                <div class="form-group">
                    <label>Add Photo</label>
                    <div class="upload-box" onclick="document.getElementById('file-input').click()">
                        <div id="image-preview" class="hidden"></div>
                        <i class="fas fa-camera-retro"></i>
                        <p>Tap to add a photo</p>
                        <input type="file" id="file-input" hidden onchange="handleImageUpload(event)">
                    </div>
                </div>

                <div class="form-group">
                    <label>Issue Title</label>
                    <input type="text" id="report-title" placeholder="e.g. Broken park bench">
                </div>

                <div class="form-group">
                    <label>Location (Pinpoint on Map)</label>
                    <div id="map"></div>
                    <input type="text" id="report-location" placeholder="Address will appear here..." readonly>
                </div>

                <div class="form-group">
                    <label>Category</label>
                    <select id="report-category">
                        <option value="Streetlight">💡 Streetlight</option>
                        <option value="Pothole">🕳️ Pothole</option>
                        <option value="Garbage">🗑️ Garbage</option>
                        <option value="Water Leak">💧 Water Leak</option>
                    </select>
                </div>

                <button class="btn-primary" onclick="submitReport()">Submit My Report</button>
            </div>
        </section>

        <section id="auth-view" class="view hidden">
            <div class="auth-container form-card">
                <h2>Secure Login</h2>
                <div class="form-group">
                    <label>Civic Email</label>
                    <input type="email" id="user-email" placeholder="neighbor@yourcity.com">
                </div>
                <button class="btn-primary" onclick="login()">Enter Dashboard</button>
            </div>
        </section>
        
        <section id="profile-view" class="view hidden">
            <div class="auth-container form-card">
                <div class="avatar-lg" id="profile-avatar">U</div>
                <h2 id="prof-email">email@locallens.com</h2>
                <button class="btn-logout" onclick="logout()">Secure Logout</button>
            </div>
        </section>
    </main>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="script.js"></script>
</body>
</html>
